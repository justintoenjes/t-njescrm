# Initialer Admin (wird beim ersten Start angelegt, falls keine User existieren)
INITIAL_ADMIN_EMAIL=admin@microcrm.local
INITIAL_ADMIN_PASSWORD=changeme

# OpenAI (für KI-Analyse und Follow-Up Generator)
OPENAI_API_KEY=sk-...
